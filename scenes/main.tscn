text = "Керування:    WASD  або  ← ↑ ↓ →  —  рух        Стрільба  —  автоматична по найближчому ворогу"

[node name="StartButton" type="Button" parent="UI/StartPanel/MarginContainer/VBoxContainer" unique_id=3455667788]

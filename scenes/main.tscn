[node name="StoryLabel" type="Label" parent="UI/StartPanel/MarginContainer/VBoxContainer" unique_id=2344556677]
custom_minimum_size = Vector2(200, 0)
size_flags_horizontal = 3
autowrap_mode = 3
text = "Пт, 17:04. Ти вже подумки на дивані з піцою, коли у Slack падає повідомлення від тімліда: «Невелика фіча, нічого складного, треба до понеділка». Ти відкриваєш таск — і в тебе темніє в очах: тисяча рядків легасі без коментарів, три зламані тести й дедлайн «вже вчора». Повіки важчають... і ти прокидаєшся вже не в офісі. Навколо суцільний код і темрява, а з усіх боків повзуть баги — живі, злі й голодні. Єдиний вихід: вижити до ранку і не вигоріти."

[node name="ControlsLabel" type="Label" parent="UI/StartPanel/MarginContainer/VBoxContainer" unique_id=778899001]
